# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
DATABASE_URL=sqlite:///cyberquest.db
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SECRET_KEY=your-secret-key-here

# Development Settings
# No extra development overrides are needed when FLASK_ENV=development

# Email Configuration (Required for email verification codes and contact form)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_USE_SSL=false
MAIL_DEBUG=false
MAIL_SUPPRESS_SEND=false
SERVER_NAME=localhost:5000

# Application Settings
POSTS_PER_PAGE=10
UPLOAD_FOLDER=app/static/uploads

# Session Configuration
PERMANENT_SESSION_LIFETIME=30

# Login Security Settings
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Vercel Deployment (automatically set by Vercel)
# VERCEL=1
# VERCEL_URL is also set automatically by Vercel; override with:
# CUSTOM_DOMAIN=your-custom-domain.com

# Production Settings (for traditional hosting)
# Set these for production deployment on platforms other than Vercel
# SECRET_KEY=your-production-secret-key-here

