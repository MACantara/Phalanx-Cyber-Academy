# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
DATABASE_URL=sqlite:///cyberquest.db
SUPABASE_URL=your-supabase-project-url
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy keys — keep until migration is verified, then deactivate in Dashboard
SUPABASE_ANON_KEY=legacy_anon_key
SUPABASE_SERVICE_ROLE_KEY=legacy_service_role_key

# Generate a secure secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Development Settings
# No extra development overrides are needed when FLASK_ENV=development

# Email Configuration (Brevo transactional email API)
BREVO_API_KEY=your-brevo-api-key
BREVO_DEFAULT_SENDER_EMAIL=your-sender@example.com
BREVO_DEFAULT_SENDER_NAME=Phalanx Cyber Academy
BREVO_SUPPRESS_SEND=false

# Application Settings
POSTS_PER_PAGE=10
UPLOAD_FOLDER=app/static/uploads

# Session Configuration
PERMANENT_SESSION_LIFETIME=30

# Login Security Settings
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Vercel Deployment (automatically set by Vercel)
# VERCEL=1
# VERCEL_URL is also set automatically by Vercel; override with:
# CUSTOM_DOMAIN=your-custom-domain.com

# Production Settings (for traditional hosting)
# Set these for production deployment on platforms other than Vercel
# SECRET_KEY=your-production-secret-key-here

# Testing
# Optional: Use a dedicated test Supabase project for integration tests
# TEST_SUPABASE_URL=your-test-supabase-project-url
# TEST_SUPABASE_SERVICE_ROLE_KEY=your-test-supabase-service-role-key
# TESTING=True
# MAIL_SUPPRESS_SEND=true

